<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>FailOr</PackageId>
    <Authors>Oneirosoft Contributors</Authors>
    <Description>Lightweight result type for explicit success and failure flows with combinators for mapping, matching, chaining, and aggregation.</Description>
    <PackageTags>result;railway-oriented-programming;functional;errors;validation;failor</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/oneirosoft/fail-or</RepositoryUrl>
    <PackageProjectUrl>https://github.com/oneirosoft/fail-or</PackageProjectUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" Link="README.md" Visible="false" />
  </ItemGroup>
</Project>
